# -----------------------------------------------------
# Powerlevel10k instant prompt (must stay near top)
# -----------------------------------------------------
if [[ -r "${XDG_CACHE_HOME:-$HOME/.cache}/p10k-instant-prompt-${(%):-%n}.zsh" ]]; then
  source "${XDG_CACHE_HOME:-$HOME/.cache}/p10k-instant-prompt-${(%):-%n}.zsh"
fi

# -----------------------------------------------------
# PATH
# -----------------------------------------------------
typeset -U path  # dedup
path=(
  "$HOME/.local/bin"
  "$HOME/.cargo/bin"
  "$HOME/.cache/.bun/bin"
  "$HOME/.local/share/pnpm"
  $path
)
# Drop nonexistent dirs silently
path=(${^path}(N-/))
export PATH

# -----------------------------------------------------
# Environment
# -----------------------------------------------------
export EDITOR='nvim'
export VISUAL='nvim'
export ZSH="$HOME/.oh-my-zsh"
export PNPM_HOME="$HOME/.local/share/pnpm"
export IDF_PATH="$HOME/esp/v5.5.2/esp-idf"
export CHROME_EXECUTABLE=/usr/bin/google-chrome-stable

# -----------------------------------------------------
# Oh My Zsh
# -----------------------------------------------------
ZSH_THEME="powerlevel10k/powerlevel10k"

plugins=(
  git
  sudo
  z
  archlinux
  web-search
  copyfile
  copybuffer
  dirhistory
  zsh-autosuggestions
  fast-syntax-highlighting
)

source "$ZSH/oh-my-zsh.sh"

# -----------------------------------------------------
# History
# -----------------------------------------------------
HISTFILE=~/.zsh_history
HISTSIZE=10000
SAVEHIST=10000
setopt append_history share_history hist_ignore_dups hist_ignore_space

# -----------------------------------------------------
# fzf (Ctrl+R fuzzy history, Ctrl+T file, Alt+C cd)
# -----------------------------------------------------
command -v fzf >/dev/null && source <(fzf --zsh)

# -----------------------------------------------------
# Tool activations
# -----------------------------------------------------
# Drop mise's cached original-PATH so re-sourcing picks up latest PATH additions.
unset __MISE_ORIG_PATH __MISE_DIFF __MISE_SESSION __MISE_ZSH_PRECMD_RUN 2>/dev/null
command -v mise >/dev/null && eval "$(mise activate zsh)"
[[ -f "$HOME/.openclaw/completions/openclaw.zsh" ]] && source "$HOME/.openclaw/completions/openclaw.zsh"
[[ -f ~/.p10k.zsh ]] && source ~/.p10k.zsh

# -----------------------------------------------------
# Aliases — listing
# -----------------------------------------------------
alias ls='lsd'
alias ll='lsd -l'
alias la='lsd -a'
alias lt='lsd --tree'

# -----------------------------------------------------
# Aliases — general
# -----------------------------------------------------
alias c='clear'
alias cls='clear'
alias ff='fastfetch'
alias v='$EDITOR'
alias vim='$EDITOR'
alias wifi='nmtui'
alias lock='hyprlock'
alias claudeD='claude --dangerously-skip-permissions'
alias update-grub='sudo grub-mkconfig -o /boot/grub/grub.cfg'

# -----------------------------------------------------
# Aliases — tmux
# -----------------------------------------------------
alias tmuxin='tmux attach -t'
alias tmuxkill='tmux kill-session -t'

# -----------------------------------------------------
# Aliases — clipboard (wayland)
# -----------------------------------------------------
alias cpwd='printf %s "$PWD" | wl-copy'
alias pp='wl-paste'

# -----------------------------------------------------
# Aliases — project navigation / dev environments
# -----------------------------------------------------
alias cproject='cd ~/code/project'
alias ctemp='cd ~/code/temp'
alias get_pio='source ~/.platformio/penv/bin/activate'
alias get_idf='. $IDF_PATH/export.sh'

# -----------------------------------------------------
# Functions
# -----------------------------------------------------

# yazi: cd into the directory yazi leaves you in
y() {
  local tmp cwd
  tmp="$(mktemp -t "yazi-cwd.XXXXXX")"
  command yazi "$@" --cwd-file="$tmp"
  IFS= read -r -d '' cwd <"$tmp"
  [[ "$cwd" != "$PWD" && -d "$cwd" ]] && builtin cd -- "$cwd"
  rm -f -- "$tmp"
}

# p2f: save wl-paste clipboard to /tmp/wl-paste/ with timestamped filename
p2f() {
  local base="/tmp/wl-paste"
  mkdir -p "$base"
  local file="$base/$(date +%Y-%m-%d_%H-%M-%S)"
  local types
  types=$(wl-paste --list-types 2>/dev/null)
  if grep -q "image/png" <<<"$types"; then
    wl-paste --type image/png >"${file}.png"
    echo "🎨 image saved: ${file}.png"
  elif grep -q "text/plain" <<<"$types"; then
    wl-paste --type text/plain >"${file}.txt"
    echo "📄 text saved: ${file}.txt"
  else
    wl-paste >"${file}.bin"
    echo "📦 binary saved: ${file}.bin"
  fi
}
